# Local dev: embedded PostgreSQL (no Docker/server install needed)
EMBEDDED_PG=true

# Production/Docker: set EMBEDDED_PG=false and use DATABASE_URL
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/qts_startup

# Or individual PG variables (used when DATABASE_URL is not set)
# PGHOST=localhost
# PGPORT=5432
# PGUSER=postgres
# PGPASSWORD=postgres
# PGDATABASE=qts_startup

DATABASE_SSL=false
DATABASE_POOL_MAX=10

# API server (internal — UI runs on WEB_PORT)
PORT=1028
# Use 127.0.0.1 for local Chrome only. Use 0.0.0.0 for MoreLogin / other profile browsers on the same PC.
HOST=127.0.0.1
ADMIN_WEB_URL=http://localhost:1027/login
AUTO_OPEN_BROWSER=true
NODE_ENV=development

# Auth
JWT_SECRET=replace-with-a-long-random-secret-change-this-in-production
JWT_EXPIRY=24h
ADMIN_USERNAME=admin
ADMIN_PASSWORD=dhaksajgkfwjfdlrwkedlrj
MANAGER_USERNAME=manager
MANAGER_PASSWORD=user
BIDDER_USERNAME=bidder
BIDDER_PASSWORD=user
CALLER_USERNAME=caller
CALLER_PASSWORD=user

# Custom GPT Actions — static Bearer secret (must match GPT editor Authentication)
GPT_ACTION_API_KEY=qts_gpt_action_replace_with_long_random_secret

# Application apply sessions: false = in-memory only (default, no DB growth during apply)
# Set true only if you need DB persistence (e.g. multi-instance serverless)
APPLICATION_SESSION_PERSIST_DB=false
