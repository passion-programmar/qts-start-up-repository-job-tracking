{
  "name": "qts-startup-server",
  "version": "1.2.0",
  "description": "QTS_Startup API server with PostgreSQL and browser extension support",
  "main": "dist/server.js",
  "bin": "dist/server.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc",
    "start": "npm run build && node dist/server.js",
    "dev": "npm run build && node --watch dist/server.js",
    "check": "tsc --noEmit",
    "build:exe": "npm run build && pkg . --compress GZip --output ../release/QTS_Startup.exe",
    "db:up": "docker compose -f ../docker-compose.yml up -d postgres",
    "db:down": "docker compose -f ../docker-compose.yml down",
    "migrate:sqlite": "node scripts/migrate-sqlite-to-pg.mjs",
    "db:reset": "npm run build && node dist/scripts/reset-db.js",
    "db:clear-bidders": "npm run build && node dist/scripts/clear-bidders-candidates.js",
    "db:clear-apply-sessions": "npm run build && node dist/scripts/clear-application-sessions.js"
  },
  "pkg": {
    "scripts": "dist/**/*.js",
    "assets": [
      "src/logo.png",
      "src/bidder-logo.png"
    ],
    "targets": [
      "node22-win-x64"
    ],
    "outputPath": "../release"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.5.3",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "jsonwebtoken": "^9.0.2",
    "pdfkit": "^0.15.2",
    "pg": "^8.22.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^22.16.0",
    "@types/pdfkit": "^0.13.9",
    "@types/pg": "^8.20.0",
    "@yao-pkg/pkg": "^6.20.0",
    "typescript": "^5.4.3"
  }
}
