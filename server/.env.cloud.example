# Copy to server/.env.cloud for Cloudflare tunnel + Neon (not committed).
# Get DATABASE_URL from https://console.neon.tech

EMBEDDED_PG=false
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx.neon.tech/neondb?sslmode=require
DATABASE_SSL=true
DATABASE_POOL_MAX=10

PORT=1028
HOST=0.0.0.0
NODE_ENV=production
AUTO_OPEN_BROWSER=false

JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRY=24h
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-strong-password
MANAGER_USERNAME=manager
MANAGER_PASSWORD=user
BIDDER_USERNAME=bidder
BIDDER_PASSWORD=user
CALLER_USERNAME=caller
CALLER_PASSWORD=user

# Set after Vercel deploy:
ADMIN_WEB_URL=https://your-app.vercel.app/login
